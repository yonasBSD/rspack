{
  "name": "@rspack/browser",
  "version": "2.0.8",
  "webpackVersion": "5.75.0",
  "license": "MIT",
  "description": "Rspack for running in the browser. This is still in early stage and may not follow the semver.",
  "type": "module",
  "types": "./dist/browser/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/index.js"
    },
    "./wasi-worker-browser.mjs": "./dist/wasi-worker-browser.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm run --fail-if-no-match --filter @rspack/core build:browser || pnpm --fail-if-no-match --filter @rspack-canary/core build:browser"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://rspack.rs",
  "bugs": "https://github.com/web-infra-dev/rspack/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rspack",
    "directory": "packages/rspack-browser"
  },
  "dependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@napi-rs/wasm-runtime": "1.1.5",
    "@rspack/lite-tapable": "1.1.2",
    "@swc/types": "0.1.26",
    "memfs": "4.57.7",
    "webpack-sources": "3.3.4"
  },
  "peerDependencies": {
    "@swc/helpers": "^0.5.23"
  },
  "peerDependenciesMeta": {
    "@swc/helpers": {
      "optional": true
    }
  }
}
