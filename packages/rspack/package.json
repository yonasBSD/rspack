{
  "name": "@rspack/core",
  "version": "2.1.0",
  "webpackVersion": "5.75.0",
  "license": "MIT",
  "description": "Fast Rust-based bundler for the web with a modernized webpack API",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hot/*": "./hot/*.js",
    "./hot/*.js": "./hot/*.js",
    "./package.json": "./package.json",
    "./module": "./module.d.ts"
  },
  "scripts": {
    "prepare": "prebundle && node ./move-tinypool.js",
    "build": "rslib build",
    "build:browser": "rslib build -c rslib.browser.config.ts",
    "dev": "rslib build --watch"
  },
  "files": [
    "dist",
    "hot",
    "compiled",
    "module.d.ts"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "homepage": "https://rspack.rs",
  "bugs": "https://github.com/web-infra-dev/rspack/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rspack",
    "directory": "packages/rspack"
  },
  "devDependencies": {
    "@ast-grep/napi": "^0.43.0",
    "@napi-rs/wasm-runtime": "1.1.5",
    "@rsbuild/plugin-node-polyfill": "^1.4.6",
    "@rslib/core": "^0.23.0",
    "@rspack/lite-tapable": "1.1.2",
    "@swc/types": "0.1.27",
    "@types/node": "^20.19.43",
    "browserslist-load-config": "^1.0.3",
    "browserslist-to-es-version": "^1.4.2",
    "connect-next": "^4.0.3",
    "enhanced-resolve": "5.24.0",
    "http-proxy-middleware": "^4.1.1",
    "memfs": "4.57.7",
    "open": "^11.0.0",
    "prebundle": "^1.6.5",
    "tinypool": "^2.1.0",
    "typescript": "^6.0.3",
    "watchpack": "2.5.2",
    "webpack-sources": "3.5.0"
  },
  "dependencies": {
    "@rspack/binding": "workspace:*"
  },
  "peerDependencies": {
    "@module-federation/runtime-tools": "^0.24.1 || ^2.0.0",
    "@swc/helpers": "^0.5.23"
  },
  "peerDependenciesMeta": {
    "@module-federation/runtime-tools": {
      "optional": true
    },
    "@swc/helpers": {
      "optional": true
    }
  }
}
