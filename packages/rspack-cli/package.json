{
  "name": "@rspack/cli",
  "version": "2.1.0-beta.0",
  "description": "CLI for rspack",
  "homepage": "https://rspack.rs",
  "bugs": "https://github.com/web-infra-dev/rspack/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rspack",
    "directory": "packages/rspack-cli"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "rspack": "./bin/rspack.js"
  },
  "files": [
    "bin",
    "compiled",
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build -w",
    "prepare": "prebundle",
    "test": "rstest"
  },
  "devDependencies": {
    "@discoveryjs/json-ext": "^1.1.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@rslib/core": "^0.22.1",
    "@rspack/core": "workspace:*",
    "@rspack/dev-server": "^2.0.3",
    "@rspack/test-tools": "workspace:*",
    "cac": "^7.0.0",
    "concat-stream": "^2.0.0",
    "cross-env": "^10.1.0",
    "execa": "^5.1.1",
    "exit-hook": "^5.1.0",
    "jiti": "^2.7.0",
    "prebundle": "^1.6.5",
    "rspack-merge": "1.0.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@rspack/core": "^2.0.0-0",
    "@rspack/dev-server": "^2.0.0-0"
  },
  "peerDependenciesMeta": {
    "@rspack/dev-server": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
